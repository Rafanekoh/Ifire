<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <title>Traduz Libras – Voz para Libras</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <style>
    body {
      margin: 0;
      font-family: system-ui, sans-serif;
      background: #0f172a;
      color: #e5e7eb;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
    }

    .container {
      max-width: 600px;
      width: 90%;
      background: #020617;
      border-radius: 16px;
      padding: 24px;
      box-shadow: 0 20px 40px rgba(0,0,0,.4);
    }

    h1 {
      text-align: center;
      color: #60a5fa;
    }

    p {
      text-align: center;
      opacity: .85;
    }

    .controls {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin: 20px 0;
    }

    button {
      padding: 14px 20px;
      font-size: 16px;
      border-radius: 12px;
      border: none;
      cursor: pointer;
      font-weight: 600;
    }

    .start { background: #22c55e; }
    .stop  { background: #ef4444; }

    textarea {
      width: 100%;
      min-height: 120px;
      border-radius: 12px;
      border: none;
      padding: 14px;
      font-size: 16px;
      background: #020617;
      color: #e5e7eb;
      box-shadow: inset 0 0 0 1px #1e293b;
    }

    .status {
      margin-top: 10px;
      text-align: center;
      font-size: 14px;
      opacity: 0.85;
    }
  </style>
</head>

<body>
  <main class="container">
    <h1>🎤 Traduz Libras</h1>
    <p>O site solicitará permissão para usar seu microfone.</p>

    <div class="controls">
      <button class="start" id="start">▶ Iniciar</button>
      <button class="stop" id="stop">■ Parar</button>
    </div>

    <textarea id="texto" placeholder="Texto reconhecido aparecerá aqui…"></textarea>
    <div class="status" id="status">Clique em iniciar para permitir o microfone.</div>
  </main>

  <!-- VLibras -->
  <div vw class="enabled">
    <div vw-access-button class="active"></div>
    <div vw-plugin-wrapper>
      <div class="vw-plugin-top-wrapper"></div>
    </div>
  </div>

  <script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>
  <script>
    new window.VLibras.Widget('https://vlibras.gov.br/app');
  </script>

  <!-- Controle de Microfone + Voz -->
 <script>
  const startBtn = document.getElementById('start');
  const stopBtn = document.getElementById('stop');
  const textarea = document.getElementById('texto');
  const status = document.getElementById('status');

  const SpeechRecognition =
    window.SpeechRecognition || window.webkitSpeechRecognition;

  if (!SpeechRecognition) {
    status.textContent = 'Reconhecimento de voz não suportado neste navegador.';
    startBtn.disabled = true;
  }

  const recognition = new SpeechRecognition();
  recognition.lang = 'pt-BR';
  recognition.continuous = true;
  recognition.interimResults = true;

  async function pedirPermissaoMicrofone() {
    try {
      await navigator.mediaDevices.getUserMedia({ audio: true });
      return true;
    } catch (err) {
      return false;
    }
  }

  startBtn.addEventListener('click', async () => {
    status.textContent = 'Solicitando permissão do microfone…';

    const permitido = await pedirPermissaoMicrofone();
    if (!permitido) {
      status.textContent = '❌ Permissão de microfone negada.';
      return;
    }

    try {
      recognition.start(); // ✅ chamado DIRETAMENTE após clique
      status.textContent = '🎙 Escutando… fale normalmente';
    } catch (err) {
      status.textContent = '⚠️ Reconhecimento já está ativo.';
    }
  });

  stopBtn.addEventListener('click', () => {
    recognition.stop();
    status.textContent = '⏹ Reconhecimento pausado.';
  });

  recognition.onresult = (event) => {
    let textoFinal = '';

    for (let i = event.resultIndex; i < event.results.length; i++) {
      if (event.results[i].isFinal) {
        textoFinal += event.results[i][0].transcript + ' ';
      }
    }

    if (textoFinal.trim()) {
      textarea.value = textoFinal.trim();
      textarea.dispatchEvent(new Event('input', { bubbles: true }));
    }
  };

  recognition.onerror = (event) => {
    if (event.error === 'not-allowed') {
      status.textContent =
        '❌ Microfone bloqueado. Verifique permissões do site no navegador.';
    } else {
      status.textContent = 'Erro no reconhecimento: ' + event.error;
    }
  };
</script>

