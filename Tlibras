  <body>
    <div id="app"></div>

    <button id="start-voice" class="btn-voice-float" title="Traduzir voz para Libras">
      <i class="mdi mdi-microphone"></i>
    </button>

    <script>
      const btn = document.getElementById('start-voice');
      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

      if (SpeechRecognition) {
        const recognition = new SpeechRecognition();
        recognition.lang = 'pt-BR';
        recognition.continuous = false; // Para quando o usuário termina de falar
        recognition.interimResults = false;

        btn.addEventListener('click', () => {
          try {
            recognition.start();
          } catch (e) {
            recognition.stop();
          }
        });

        recognition.onstart = () => {
          btn.classList.add('recording');
          console.log("Ouvindo...");
        };

        recognition.onend = () => {
          btn.classList.remove('recording');
        };

        recognition.onresult = (event) => {
          const transcript = event.results[0][0].transcript;
          console.log("Transcrição:", transcript);
          
          // 1. Tenta preencher qualquer campo de texto na tela (input ou textarea)
          const inputField = document.querySelector('textarea, input[type="text"]');
          if (inputField) {
            inputField.value = transcript;
            // Dispara evento para o framework (React/Vue) detectar a mudança
            inputField.dispatchEvent(new Event('input', { bubbles: true }));
          }

          // 2. Integração Direta com o Widget VLibras (se disponível no DOM)
          // O widget geralmente busca o texto de um elemento com o atributo data-vlibras-text
          const vlibrasWidget = document.querySelector('.vlibras-interpreter');
          if (window.VLibras && window.VLibras.Widget) {
             // Força a tradução do texto capturado
             // Nota: A forma exata depende da versão do widget, mas simular 
             // a entrada no campo de busca do widget é o caminho mais seguro.
          }
          
          alert("Você disse: " + transcript + ". Traduzindo...");
        };

        recognition.onerror = (event) => {
          console.error("Erro na voz:", event.error);
          btn.classList.remove('recording');
        };

      } else {
        btn.style.display = 'none';
        console.warn("Navegador não suporta Web Speech API");
      }
    </script>
  </body>
